{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ph/flipbook-block",
    "version": "1.0.0",
    "title": "Flipbook Block",
    "category": "widgets",
    "icon": "book",
    "attributes": {
        "pdfUrl": {
            "type": "string",
            "source": "attribute",
            "selector": "div[data-pdf-url]",
            "attribute": "data-pdf-url"
        },
        "blockId": {
            "type": "string"
        },
        "pdfId": {
            "type": "number"
        },
        "toolbar": {
            "type": "boolean",
            "default": true
        },
        "toolbarAlwaysVisible": {
            "type": "boolean",
            "default": true
        },
        "enableFullscreen": {
            "type": "boolean",
            "default": true
        },
        "enableDownload": {
            "type": "boolean",
            "default": false
        },
        "downloadFilename": {
            "type": "string",
            "default": ""
        },
        "singlePageMode": {
            "type": "boolean",
            "default": false
        },
        "flipDuration": {
            "type": "number",
            "default": 800
        },
        "startPage": {
            "type": "number",
            "default": 1
        },
        "height": {
            "type": "string",
            "default": "100vh"
        }
    },
    "supports": {
        "html": false,
        "align": [ "wide", "full" ]
    },
    "textdomain": "flipbook-block",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "viewScript": "file:./view.js",
    "viewStyle": "file:./view.css"
}
